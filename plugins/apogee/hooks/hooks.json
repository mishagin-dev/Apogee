{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/git/enforce-git-commit-skill.py\"" },
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/git/enforce-git-flow-skill.py\"" }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/idea/idea-symbol-guard.py\"" }
        ]
      },
      {
        "matcher": "Glob",
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/idea/idea-glob-guard.py\"" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/idea/idea-bash-grep-guard.py\"" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/lang/tool-lang-guard.py\"" }
        ]
      },
      {
        "matcher": "mcp__",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/core/security-scan.sh\"" }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/br/br-edit-gate.py\"" },
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/br/br-branch-gate.py\"" }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/idea/idea-read-gate.py\"" }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/idea/idea-agent-guard.py\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__idea__.*",
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/idea/idea-usage-tracker.py\"" }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/br/br-capture-gate.py\"" }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/review/skill-run-tracker.py\"" }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/review/track-file-touch.sh\"" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/idea/idea-nudge.py\"" },
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/git/unfinished-branch-nudge.py\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/review/review-docs-gate.sh\"", "timeout": 10000 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/br/br-progress-gate.sh\"", "timeout": 10000 }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/core/notify.sh\" input" }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/br/br-prime.sh\"" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/core/gated.sh\" \"${CLAUDE_PLUGIN_ROOT}/hooks/core/snapshot-baseline.sh\"" },
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/core/apogee-session-start.py\"" },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/br/br-prime.sh\"" },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/br/br-snapshot.sh\"" },
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/idea/idea-force-activate.py\"" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/core/cleanup-session.sh\"" }
        ]
      }
    ]
  }
}
