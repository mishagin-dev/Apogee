{
  "enabled": true,
  "min_lines_changed": 10,
  "review_threshold": 50,
  "file_patterns": ["*.py", "*.ts", "*.js", "*.swift", "*.go", "*.rs"],
  "review_command": "/apogee:review-work",
  "test_command": null,
  "docs_command": "/apogee:update-docs",
  "phases": {
    "review": true,
    "tests": true,
    "docs": true
  }
}
